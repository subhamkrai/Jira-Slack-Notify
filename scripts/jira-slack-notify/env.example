# Copy to env (gitignored), then run watch.sh locally:
#   cp scripts/jira-slack-notify/env.example scripts/jira-slack-notify/env

JIRA_EMAIL=
JIRA_API_TOKEN=

# Atlassian cloud ID for your Jira site:
#   curl -s "https://YOUR_SITE.atlassian.net/_edge/tenant_info" | jq -r .cloudId
JIRA_CLOUD_ID=

# Slack Workflow Builder webhook for instant notifications
SLACK_NOTIFY_WEBHOOK_URL=https://hooks.slack.com/triggers/T00000000/0000000000/xxxxxxxxxxxxxxxxxxxxxxxx

# Workflow webhook variables (type: Text) — names must match JSON keys exactly:
#   headline, url, summary
#
# In "Send a message" (do NOT wrap variables in code formatting):
#
#   *{{headline}}*
#   {{url}}
#   *Summary*
#   {{summary}}

# Optional
# JIRA_PROJECT=DFBUGS
# JIRA_SITE=redhat.atlassian.net
# JIRA_SLACK_STATE_FILE=/path/to/.watch-state.json
